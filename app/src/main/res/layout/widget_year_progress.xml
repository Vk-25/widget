<?xml version="1.0" encoding="utf-8"?>
<!--
    widget_year_progress.xml — Year Progress  (deep black glass)
    ─────────────────────────────────────────────────────────────
    • bg: @drawable/widget_background → near-opaque black (#E5)
    • Title #F4F4F8 — almost pure white, max contrast
    • Subtitle #B0B0B8 — 70% bright grey, clearly visible
    • iv_dots: transparent bitmap over black → vivid glow pops
    • adjustViewBounds=true → zero vertical stretch / blur
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:paddingLeft="14dp"
    android:paddingRight="14dp"
    android:paddingTop="12dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Year Progress"
        android:textColor="#F4F4F8"
        android:textSize="17sp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.02"
        android:layout_marginBottom="2dp"/>

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2026 · Day 79 of 365 · 21.6%"
        android:textColor="#B0B0B8"
        android:textSize="10sp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.04"
        android:layout_marginBottom="8dp"/>

    <ImageView
        android:id="@+id/iv_dots"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scaleType="fitXY"
        android:adjustViewBounds="true"
        android:background="@android:color/transparent"/>

</LinearLayout>