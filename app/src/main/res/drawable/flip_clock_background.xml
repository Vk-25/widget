<?xml version="1.0" encoding="utf-8"?>
<!--
    flip_clock_background.xml
    ──────────────────────────────────────────────────────────────────────────
    FULLY TRANSPARENT container.
    The glass effect lives entirely inside the card bitmaps drawn by
    FlipClockWidget.card(). The outer widget frame has no tinted fill —
    the home-screen wallpaper shows through completely.
    Only a hair-thin specular stroke remains to define the widget boundary
    when the wallpaper is very dark.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Completely transparent — no black or coloured tile -->
    <solid android:color="#00000000" />

    <!-- Large iOS-style radius -->
    <corners android:radius="22dp" />

    <!-- Hair-thin specular rim: visible on dark wallpapers, invisible on light -->
    <stroke
        android:width="1dp"
        android:color="#20FFFFFF" />

</shape>